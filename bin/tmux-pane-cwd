#!/usr/bin/env bash
# Print the cwd of the deepest descendant of $1 (a tmux pane's PID), falling
# back to $2 if no descendants exist or the cwd lookup fails. Used by the
# new-window/split bindings in .tmux.conf so that long-running TUIs (Claude
# Code, anything that drives a persistent inner subshell) leak their actual
# working directory through to tmux. tmux's #{pane_current_path} reflects the
# foreground process's cwd, but when that process is a TUI it never chdir()s
# itself — its inner bash does — so #{pane_current_path} stays pinned to wherever
# the TUI was launched. Walking descendants surfaces the cwd the user means.
set -euo pipefail

pane_pid="${1:-}"
fallback="${2:-}"

emit_fallback() { printf '%s\n' "$fallback"; exit 0; }

[[ -z "$pane_pid" ]] && emit_fallback

# BFS the descendant tree. Depth cap of 6 matches recon's MAX_DEPTH and is more
# than enough for real wrapper chains (slack -> deno -> claude -> bash).
# Uses bash 3.2-compatible primitives (no associative arrays — macOS still ships 3.2).
seen=" $pane_pid "
queue=("$pane_pid:0")
deepest_pid=""
deepest_depth=0

while ((${#queue[@]} > 0)); do
  head="${queue[0]}"
  queue=("${queue[@]:1}")
  pid="${head%:*}"
  depth="${head##*:}"
  ((depth >= 6)) && continue

  while IFS= read -r child; do
    [[ -z "$child" ]] && continue
    [[ "$seen" == *" $child "* ]] && continue
    seen="$seen$child "
    new_depth=$((depth + 1))
    if ((new_depth > deepest_depth)); then
      deepest_pid="$child"
      deepest_depth=$new_depth
    fi
    queue+=("$child:$new_depth")
  done < <(pgrep -P "$pid" 2>/dev/null || true)
done

[[ -z "$deepest_pid" ]] && emit_fallback

# macOS has no /proc; use lsof's machine-readable -F output. Linux uses /proc.
cwd=""
case "$(uname)" in
  Darwin)
    cwd="$(lsof -a -p "$deepest_pid" -d cwd -Fn 2>/dev/null | sed -n 's/^n//p' | head -n1 || true)"
    ;;
  Linux)
    cwd="$(readlink "/proc/$deepest_pid/cwd" 2>/dev/null || true)"
    ;;
esac

if [[ -n "$cwd" && -d "$cwd" ]]; then
  printf '%s\n' "$cwd"
else
  emit_fallback
fi
